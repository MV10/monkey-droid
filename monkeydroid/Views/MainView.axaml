<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:monkeydroid.ViewModels"
             xmlns:views="using:monkeydroid.Views"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="720"
             x:Class="monkeydroid.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Panel>

    <!-- Splash Screen -->
    <Panel Name="SplashPanel" IsVisible="{Binding IsSplashActive}" ZIndex="10"
           Background="{DynamicResource SystemRegionBrush}">
      <Border HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="200" Height="200" CornerRadius="100"
              ClipToBounds="True">
        <Image Source="/Assets/icon.png" Stretch="UniformToFill"
               Width="200" Height="200" />
      </Border>
    </Panel>

    <!-- Main content area -->
    <DockPanel>

      <!-- Titlebar -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource SystemAccentColor}"
              Padding="8" IsVisible="{Binding ShowNavigation}">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Hamburger button -->
          <Button Grid.Column="0" Content="&#x2630;" FontSize="20"
                  Background="Transparent" Foreground="White"
                  Padding="8,4" Name="HamburgerButton"
                  IsVisible="{Binding ShowHamburgerMenu}" />

          <!-- Title -->
          <TextBlock Grid.Column="1" Text="{Binding CurrentTitle}"
                     Foreground="White" FontSize="18" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />

          <!-- Nav buttons — hidden on non-sequence views -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12"
                      IsVisible="{Binding ShowNavArrows}">
            <Button Content="&#x276E;" FontSize="18"
                    Background="Transparent" Foreground="White" Padding="8,4"
                    Command="{Binding GoBackCommand}" />
            <Button Content="&#x276F;" FontSize="18"
                    Background="Transparent" Foreground="White" Padding="8,4"
                    Command="{Binding GoForwardCommand}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Page content -->
      <ContentControl Content="{Binding CurrentPage}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:ServerListViewModel">
            <views:ServerListView />
          </DataTemplate>
          <DataTemplate DataType="vm:PlaylistsViewModel">
            <views:PlaylistsView />
          </DataTemplate>
          <DataTemplate DataType="vm:CommonControlsViewModel">
            <views:CommonControlsView />
          </DataTemplate>
          <DataTemplate DataType="vm:VisualizersViewModel">
            <views:VisualizersView />
          </DataTemplate>
          <DataTemplate DataType="vm:FxViewModel">
            <views:FxView />
          </DataTemplate>
          <DataTemplate DataType="vm:ConsoleViewModel">
            <views:ConsoleView />
          </DataTemplate>
          <DataTemplate DataType="vm:AboutViewModel">
            <views:AboutView />
          </DataTemplate>
          <DataTemplate DataType="vm:HelpViewModel">
            <views:HelpView />
          </DataTemplate>
          <DataTemplate DataType="vm:ServerEditorViewModel">
            <views:ServerEditorView />
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </DockPanel>

    <!-- Overlay host: all overlays are added here in code-behind -->
    <Panel Name="OverlayHost" ZIndex="5" />

  </Panel>
</UserControl>
