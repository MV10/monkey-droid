<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:monkeydroid.ViewModels"
             xmlns:m="using:monkeydroid.Models"
             x:Class="monkeydroid.Views.FxView"
             x:DataType="vm:FxViewModel">

  <DockPanel>

    <!-- Timestamp -->
    <TextBlock DockPanel.Dock="Top" Text="{Binding Timestamp}"
               FontSize="11" Foreground="Gray" Margin="16,4,16,0"
               HorizontalAlignment="Center"
               IsVisible="{Binding Timestamp, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <!-- Load button at bottom -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="1*,4*"
          Margin="16,8,16,16">
      <Button Grid.Column="0" Content="&#x21BB;" FontSize="18"
              Command="{Binding LoadListCommand}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              Padding="8" Classes="accent" />
    </Grid>

    <!-- FX list -->
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding FxList}" Margin="16,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="m:FxInfo">
            <Button Margin="0,2" Padding="12,8" CornerRadius="4"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding AudioIcon}"
                             FontSize="12" Foreground="Gray" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="Gray"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
