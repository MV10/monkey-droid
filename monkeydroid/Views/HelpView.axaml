<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:monkeydroid.ViewModels"
             x:Class="monkeydroid.Views.HelpView"
             x:DataType="vm:HelpViewModel">

  <DockPanel>
    <Button DockPanel.Dock="Bottom" Content="Ok" Name="OkButton"
            HorizontalAlignment="Center" MinWidth="100"
            HorizontalContentAlignment="Center" Classes="accent"
            Margin="0,0,0,24" Padding="12,8" />

    <TextBlock Text="Help" FontSize="24"
               HorizontalAlignment="Center" VerticalAlignment="Center" />
  </DockPanel>
</UserControl>
